{
  "__inputs": [
    {
      "name": "prometheus_datasource",
      "label": "Prometheus",
      "description": "Prometheus datasource for Central-auth and infrastructure metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "loki_datasource",
      "label": "Loki",
      "description": "Loki datasource for structured log queries (news throughput, request_id tracing)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
        "enable": true,
        "expr": "changes(central_auth_circuit_breaker_state[1m]) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Circuit Breaker State Change",
        "step": "60s",
        "titleFormat": "CB {{circuit_state}}"
      }
    ]
  },
  "description": "Hackonomics 2026 Pipeline Observability — Login Rate | News Throughput | Kafka Lag",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "logins / min",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "line"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "green", "value": 10}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "rate(central_auth_auth_operations_total{operation=\"login\",result=\"ok\"}[5m]) * 60",
          "legendFormat": "login success / min",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "rate(central_auth_auth_operations_total{operation=\"login\",result=\"error\"}[5m]) * 60",
          "legendFormat": "login error / min",
          "refId": "B"
        }
      ],
      "title": "Login Success Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 6, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "count_over_time({service_name=\"hackonomics-app\"} |= \"News updated\" [$__range])",
          "legendFormat": "News items saved",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "title": "News Collection Throughput",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "Caught up"}}, "type": "value"}
          ],
          "max": 10000,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 5000}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 6, "x": 18, "y": 0},
      "id": 3,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "central_auth_kafka_consumer_lag",
          "legendFormat": "Consumer lag (messages)",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag (Real-time)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req / sec",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "rate(central_auth_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "CLOSED"}}, "type": "value"},
            {"options": {"1": {"color": "red", "index": 1, "text": "OPEN"}}, "type": "value"},
            {"options": {"2": {"color": "yellow", "index": 2, "text": "HALF-OPEN"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1},
              {"color": "yellow", "value": 2}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 9},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "central_auth_circuit_breaker_state",
          "legendFormat": "CB State",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "orange", "mode": "fixed"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 9},
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
          "expr": "increase(central_auth_circuit_breaker_trips_total[$__range])",
          "legendFormat": "CB Trips",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker Trips",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "log events / sec",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 0,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "error"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "warn"},
            "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 17},
      "id": 7,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "sum by (level) (count_over_time({namespace=\"$namespace\"} | json | level != \"\" [$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "title": "Log Volume by Level (All Services)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["hackonomics", "pipeline", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "prometheus_datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {"selected": false, "text": "default", "value": "default"},
        "datasource": {"type": "prometheus", "uid": "${prometheus_datasource}"},
        "definition": "label_values(central_auth_http_requests_total, namespace)",
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "name": "namespace",
        "options": [],
        "query": "label_values(central_auth_http_requests_total, namespace)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Hackonomics Pipeline",
  "uid": "hackonomics-pipeline-v1",
  "version": 1,
  "weekStart": ""
}
